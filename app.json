{
  "expo": {
    "name": "Reach",
    "slug": "reach-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "reach",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reach.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE6"
      },
      "package": "com.reach.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png",
      "themeColor": "#E0D4C4",
      "backgroundColor": "#E0D4C4",
      "manifest": {
        "name": "Reach",
        "short_name": "Reach",
        "icons": [
          {
            "src": "/icon.png",
            "sizes": "192x192",
            "type": "image/png"
          },
          {
            "src": "/icon.png",
            "sizes": "512x512",
            "type": "image/png"
          }
        ]
      }
    },
    "updates": {
      "url": "https://u.expo.dev/f3782ce6-b211-41c3-803d-e4d3e8e8f27c",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3782ce6-b211-41c3-803d-e4d3e8e8f27c"
      }
    },
    "owner": "reach_pr"
  }
}
