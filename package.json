{
  "name": "reach-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "test:unit": "jest __tests__/unit.test.ts --verbose",
    "test:integration": "jest __tests__/integration.test.ts --verbose",
    "test:unit:coverage": "jest __tests__/unit.test.ts --coverage",
    "test:e2e": "playwright test __tests__/e2e.spec.ts --reporter=list",
    "test:load": "node __tests__/load.test.js",
    "test:regression": "jest --verbose && playwright test __tests__/e2e.spec.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:load"
  },
  "dependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@napi-rs/canvas": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.12.0",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/og": "^0.11.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "^0.32.17",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "html2canvas": "^1.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-iap": "^15.3.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "^5.1.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "autocannon": "^8.0.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^56.0.14",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
